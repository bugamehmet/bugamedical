<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="shortcut icon" type="png" href="/assets/images/favicon.png" />

		<title><%= pageTitle || 'BugaMed - MRI & CT Parts' %></title>

		<meta
			name="description"
			content="<%= metaDescription || 'MRI, CT, X-Ray parts and service by BugaMedical.' %>"
		/>

		<% if (canonicalUrl) { %>
		<link rel="canonical" href="https://www.bugamedical.com<%= canonicalUrl %>" />
		<% } %>

<link rel="preload" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css" as="style" onload="this.onload=null;this.rel='stylesheet'" />
<noscript>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css" />
</noscript>
<link rel="stylesheet" href="/assets/css/global.css" />
<link rel="stylesheet" href="/assets/css/header.css" />


	</head>

	<body>
<header>
  <nav id="navbar">

    <!-- Logo -->
    <a href="/" class="nav-logo">
      <img src="/assets/images/buga-logo.webp" alt="BugaMed Logo" />
    </a>
		    <!-- Mobil hamburger -->
    <a href="javascript:void(0);" class="nav-icon" onclick="navFunction()">
      <i class="fa fa-bars"></i>
    </a>

    <!-- Linkler -->
    <div class="nav-links">
      <a href="/" class="<%= currentPage === 'home' ? 'active' : '' %>">Home</a>
      <a href="/parts-catalog" class="<%= currentPage === 'parts' ? 'active' : '' %>">Parts Catalog</a>
      <a href="/why" class="<%= currentPage === 'why' ? 'active' : '' %>">Why Bugamed</a>
      <a href="/about" class="<%= currentPage === 'about' ? 'active' : '' %>">About</a>
      <a href="/contactus" class="<%= currentPage === 'contact' ? 'active' : '' %>">Contact Us</a>
      <a href="/photos" class="<%= currentPage === 'photos' ? 'active' : '' %>">Gallery</a>
    </div>

    <!-- Search -->
    <div class="nav-search">
      <form id="navSearchForm" action="/search" method="GET" autocomplete="off">
        <input
          id="navSearchInput"
          type="text"
          placeholder="Enter Part Number or Part Name"
          name="q"
          value="<%= (typeof searchQuery !== 'undefined' && searchQuery) ? searchQuery : '' %>"
        />
        <button type="submit" aria-label="Search">
          <i class="fa fa-search"></i>
        </button>
      </form>
    </div>

  </nav>
</header>




		<div id="navSearchDropdown" class="search-dropdown"></div>

		<script>
			function navFunction() {
				document.querySelector('.nav-links').classList.toggle('open');
				document.querySelector('.nav-search').classList.toggle('open');
			}

			(function () {
				const input = document.getElementById('navSearchInput');
				const dropdown = document.getElementById('navSearchDropdown');
				if (!input || !dropdown) return;

				let timer = null;
				let aborter = null;
				let items = [];
				let activeIndex = -1;

				function esc(s) {
					return String(s || '')
						.replace(/&/g, '&amp;')
						.replace(/</g, '&lt;')
						.replace(/>/g, '&gt;')
						.replace(/"/g, '&quot;')
						.replace(/'/g, '&#39;');
				}

				function placeDropdown() {
					const r = input.getBoundingClientRect();
					dropdown.style.left = r.left + 'px';
					dropdown.style.top = r.bottom + 6 + 'px';
					// input genişliğine göre mantıklı bir genişlik
					const w = Math.min(520, Math.max(320, r.width + 160));
					dropdown.style.width = w + 'px';
				}

				function closeDropdown() {
					dropdown.style.display = 'none';
					dropdown.innerHTML = '';
					items = [];
					activeIndex = -1;
				}

				function openDropdown() {
					placeDropdown();
					dropdown.style.display = 'block';
				}

				function render(list) {
					if (!list || !list.length) {
						dropdown.innerHTML = `<div class="search-empty">No results</div>`;
						openDropdown();
						return;
					}

					dropdown.innerHTML = list
						.map(
							(it, idx) => `
								<div class="search-item ${idx === activeIndex ? 'active' : ''}" data-idx="${idx}">
									<div class="left">
										<div class="title">${esc(it.name || '(No name)')}</div>
										<div class="meta">
											${esc(it.oem || '')}${it.mpn ? ' • MPN: ' + esc(it.mpn) : ''}
										</div>
									</div>
									<div class="right">${esc(it.sku || '')}</div>
								</div>
							`
						)
						.join('');

					openDropdown();
				}

				async function fetchSuggest(q) {
					if (aborter) aborter.abort();
					aborter = new AbortController();

					const res = await fetch(`/api/search-suggest?q=${encodeURIComponent(q)}`, {
						signal: aborter.signal,
					});

					const data = await res.json().catch(() => null);
					return data && data.ok && Array.isArray(data.items) ? data.items : [];
				}

				input.addEventListener('input', function () {
					const q = input.value.trim();
					if (timer) clearTimeout(timer);

					if (q.length < 2) {
						closeDropdown();
						return;
					}

					timer = setTimeout(async () => {
						try {
							const list = await fetchSuggest(q);
							items = list;
							activeIndex = -1;
							render(items);
						} catch (e) {
							if (e && e.name === 'AbortError') return;
							closeDropdown();
						}
					}, 250);
				});

				input.addEventListener('keydown', function (e) {
					if (dropdown.style.display !== 'block') return;

					if (e.key === 'ArrowDown') {
						e.preventDefault();
						activeIndex = Math.min(activeIndex + 1, items.length - 1);
						render(items);
					} else if (e.key === 'ArrowUp') {
						e.preventDefault();
						activeIndex = Math.max(activeIndex - 1, 0);
						render(items);
					} else if (e.key === 'Enter') {
						if (activeIndex >= 0 && items[activeIndex]?.url) {
							e.preventDefault();
							window.location.href = items[activeIndex].url;
						}
						// yoksa normal form submit -> /search?q=
					} else if (e.key === 'Escape') {
						closeDropdown();
					}
				});

				dropdown.addEventListener('mousedown', function (e) {
					const row = e.target.closest('.search-item');
					if (!row) return;
					const idx = Number(row.getAttribute('data-idx'));
					if (items[idx]?.url) window.location.href = items[idx].url;
				});

				document.addEventListener('click', function (e) {
					if (e.target === input) return;
					if (dropdown.contains(e.target)) return;
					closeDropdown();
				});

				// ✅ scroll/resize olunca dropdown input'un altında kalmaya devam etsin
				window.addEventListener('resize', () => {
					if (dropdown.style.display === 'block') placeDropdown();
				});
				window.addEventListener(
					'scroll',
					() => {
						if (dropdown.style.display === 'block') placeDropdown();
					},
					true
				);

				input.addEventListener('blur', function () {
					setTimeout(() => {
						if (!dropdown.matches(':hover')) closeDropdown();
					}, 150);
				});
			})();
		</script>
	</body>
</html>
