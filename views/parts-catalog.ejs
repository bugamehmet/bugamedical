<%- include('partials/header', { pageTitle, metaDescription, canonicalUrl, currentPage }) %>
<style>
	.product-card {
		background: #ffffff;
		border-radius: 10px;
		padding: 12px;
		box-shadow: 0 3px 10px rgba(0, 0, 0, 0.08);
		transition: all 0.2s ease;
		overflow: hidden; /* 🧷 Kartın dışına çıkanı kes */
		display: flex;
		flex-direction: column;
	}

	.product-image-wrapper {
		width: 100%;
		height: 150px; /* Kart yüksekliği tutulsun */
		border-radius: 8px;
		overflow: hidden; /* 🧷 Resim bu kutunun dışına taşmasın */
		background: #f8f8f8;
		display: flex;
		justify-content: center;
		align-items: center;
		margin-bottom: 8px;
	}

	.product-thumb {
		max-width: 100%;
		max-height: 100%;
		width: auto;
		height: auto;
		object-fit: contain; /* Resmi kırpmadan sığdır */
		display: block;
	}
</style>

<main class="page-content">
	<div class="product-grid">
		<% if (products && products.length > 0) { %> <% products.forEach(function(p) { %>
		<a class="product-link" href="/part/<%= p.sku %>/<%= p.slug || '' %>">
			<div class="product-card">
				<div class="product-image-wrapper">
					<img src="<%= p.imageUrl %>" alt="<%= p.name %>" class="product-thumb" loading="lazy" />
				</div>

				<h2 class="product-name"><%= p.name %></h2>

				<p class="product-model">System Model: <%= p.system || 'MRI / CT System' %></p>

				<div class="product-meta">
					<div class="meta-row">
						<span class="meta-label">Serial No:</span>
						<span class="meta-value"><%= p.serialNumber || p.sku %></span>
					</div>
					<div class="meta-row">
						<span class="meta-label">Condition:</span>
						<span class="status-pill status-working">
							<%= p.condition || 'Working - Tested' %>
						</span>
					</div>
				</div>
			</div>
		</a>

		<% }) %> <% } else { %>
		<p>No products found.</p>
		<% } %>
	</div>
</main>

<%- include('partials/footer') %>
