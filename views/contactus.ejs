<%- include('partials/header', {
	pageTitle: 'BugaMed - MRI & CT Parts | Contact Us',
	metaDescription: 'Contact BugaMed Care for MRI, CT, and X-ray equipment parts or technical support. Our team is ready to assist with fast response times.',
	canonicalUrl: '/contactus',
	currentPage: 'contact'
}) %>

<style>
	body {
		margin: 0;
		font-family:
			system-ui,
			-apple-system,
			BlinkMacSystemFont,
			'Segoe UI',
			sans-serif;
		background: #f3f4f6;
		color: #111827;
	}

	.contact-page {
		max-width: 1200px;
		margin: 40px auto 0 auto;
		padding: 0 20px 60px;
	}

	.contact-hero {
		text-align: center;
		margin-bottom: 30px;
	}

	.contact-hero h1 {
		font-size: 32px;
		font-weight: 700;
		margin-bottom: 10px;
	}

	.contact-hero p {
		font-size: 15px;
		color: rgb(109, 131, 113);
		max-width: 700px;
		margin: 0 auto;
	}

	.contact-wrapper {
		display: grid;
		grid-template-columns: minmax(0, 1.6fr) minmax(0, 1fr);
		gap: 24px;
		align-items: start;
	}

	.contact-form-card,
	.contact-info-card {
		background: #ffffff;
		border-radius: 12px;
		padding: 22px 20px;
		border: 1px solid #e5e7eb;
		box-shadow: 0 8px 20px rgba(15, 23, 42, 0.06);
	}

	.contact-form-card h2,
	.contact-info-card h2 {
		font-size: 22px;
		margin-top: 0;
		margin-bottom: 16px;
	}

	.contact-form-card p,
	.contact-info-card p,
	.contact-info-card li {
		font-size: 14px;
		color: #4b5563;
		line-height: 1.6;
	}

	.contact-form-group {
		margin-bottom: 14px;
	}

	.contact-form-group label {
		display: block;
		font-size: 14px;
		font-weight: 600;
		margin-bottom: 6px;
		color: #111827;
	}

	.contact-form-card input,
	.contact-form-card select,
	.contact-form-card textarea {
		width: 100%;
		padding: 12px 14px;
		font-size: 14px;
		border: 1px solid #d1d5db;
		border-radius: 10px;
		box-sizing: border-box;
		background: #fff;
		color: #111827;
		outline: none;
		transition:
			border-color 0.2s ease,
			box-shadow 0.2s ease;
	}

	.contact-form-card input:focus,
	.contact-form-card select:focus,
	.contact-form-card textarea:focus {
		border-color: rgb(109, 131, 113);
		box-shadow: 0 0 0 3px rgba(109, 131, 113, 0.12);
	}

	.contact-form-card textarea {
		min-height: 180px;
		resize: vertical;
	}

	.contact-btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 8px;
		width: 100%;
		border: none;
		border-radius: 999px;
		padding: 12px 18px;
		font-size: 14px;
		font-weight: 600;
		cursor: pointer;
		background: rgb(109, 131, 113);
		color: #ffffff;
		transition:
			background 0.2s ease,
			transform 0.2s ease;
	}

	.contact-btn:hover {
		background: #1d4ed8;
		transform: translateY(-1px);
	}

	#formMessage {
		margin-top: 14px;
		font-size: 13px;
		font-weight: 500;
	}

	.message-success {
		color: #15803d;
	}

	.message-error {
		color: #b91c1c;
	}

	.info-list {
		display: grid;
		gap: 14px;
		margin-bottom: 20px;
	}

	.info-item {
		display: flex;
		align-items: flex-start;
		gap: 12px;
	}

	.info-item i {
		font-size: 18px;
		color: rgb(109, 131, 113);
		margin-top: 2px;
		min-width: 20px;
	}

	.info-item a {
		color: #111827;
		text-decoration: none;
	}

	.info-item a:hover {
		color: rgb(109, 131, 113);
	}

	.contact-note {
		margin-top: 18px;
		padding: 14px 16px;
		background: #f9fafb;
		border: 1px solid #e5e7eb;
		border-radius: 10px;
	}

	.contact-note strong {
		display: block;
		margin-bottom: 6px;
		font-size: 14px;
		color: #111827;
	}

	@media (max-width: 900px) {
		.contact-wrapper {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 768px) {
		.contact-hero h1 {
			font-size: 26px;
		}
	}
</style>

<main class="contact-page">
	<section class="contact-hero">
		<h1>Contact BugaMed</h1>
		<p>
			Get in touch for MRI, CT and X-Ray parts, technical support, availability requests or
			project inquiries.
		</p>
	</section>

	<section class="contact-wrapper">
		<div class="contact-form-card">
			<h2>Send a Message</h2>
			<p>
				If you are looking for a specific part or need technical support, send us your request
				and we will get back to you as soon as possible.
			</p>

			<form id="contactForm">
				<div class="contact-form-group">
					<label for="name">Full Name</label>
					<input type="text" id="name" name="name" placeholder="Your full name" required />
				</div>

				<div class="contact-form-group">
					<label for="email">Email</label>
					<input
						type="email"
						id="email"
						name="email"
						placeholder="Your email address"
						required
					/>
				</div>

				<div class="contact-form-group">
					<label for="country">Country</label>
					<select id="country" name="country">
						<option value="">Select Country</option>
						<option value="usa">USA</option>
						<option value="germany">Germany</option>
						<option value="australia">Australia</option>
						<option value="belgium">Belgium</option>
						<option value="brazil">Brazil</option>
						<option value="china">China</option>
						<option value="denmark">Denmark</option>
						<option value="finland">Finland</option>
						<option value="france">France</option>
						<option value="south-korea">South Korea</option>
						<option value="india">India</option>
						<option value="netherlands">Netherlands</option>
						<option value="uk">United Kingdom</option>
						<option value="ireland">Ireland</option>
						<option value="spain">Spain</option>
						<option value="israel">Israel</option>
						<option value="sweden">Sweden</option>
						<option value="switzerland">Switzerland</option>
						<option value="italy">Italy</option>
						<option value="japan">Japan</option>
						<option value="canada">Canada</option>
						<option value="mexico">Mexico</option>
						<option value="norway">Norway</option>
						<option value="russia">Russia</option>
						<option value="singapore">Singapore</option>
						<option value="turkey">Turkey</option>
						<option value="uae">United Arab Emirates</option>
					</select>
				</div>

				<div class="contact-form-group">
					<label for="message">Message</label>
					<textarea
						id="message"
						name="message"
						placeholder="Write your message here..."
						required
					></textarea>
				</div>

				<button type="submit" class="contact-btn">
					<i class="fa fa-paper-plane-o"></i>
					Send Message
				</button>

				<div id="formMessage"></div>
			</form>
		</div>

		<div class="contact-info-card">
			<h2>Contact Information</h2>

			<div class="info-list">
				<div class="info-item">
					<i class="fa fa-phone"></i>
					<div>
						<strong>Phone</strong>
						<p><a href="tel:+905367210565">+90 536 721 05 65</a></p>
					</div>
				</div>

				<div class="info-item">
					<i class="fa fa-envelope"></i>
					<div>
						<strong>Email</strong>
						<p><a href="mailto:bugamedical@gmail.com">bugamedical@gmail.com</a></p>
					</div>
				</div>

				<div class="info-item">
					<i class="fa fa-map-marker"></i>
					<div>
						<strong>Location</strong>
						<p>Samsun, Turkey</p>
					</div>
				</div>
			</div>

			<div class="contact-note">
				<strong>What can you contact us for?</strong>
				<p>
					MRI, CT and X-Ray spare parts, technical support, availability checks, replacement
					options and project-based inquiries.
				</p>
			</div>
		</div>
	</section>
</main>

<script>
	document.getElementById('contactForm').addEventListener('submit', async function (event) {
		event.preventDefault();

		const name = document.getElementById('name').value.trim();
		const email = document.getElementById('email').value.trim();
		const country = document.getElementById('country').value;
		const message = document.getElementById('message').value.trim();
		const subject = 'Contact Form';

		const formMessageDiv = document.getElementById('formMessage');
		formMessageDiv.textContent = '';
		formMessageDiv.className = '';

		try {
			const response = await fetch('/send-email', {
				method: 'POST',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify({
					name,
					email,
					subject,
					message,
					country,
					source: 'Contact Us Page',
				}),
			});

			const result = await response.json();

			if (result.success) {
				formMessageDiv.textContent = result.message || 'Message sent successfully.';
				formMessageDiv.classList.add('message-success');
				document.getElementById('contactForm').reset();
			} else {
				formMessageDiv.textContent =
					result.message || 'Something went wrong. Please try again.';
				formMessageDiv.classList.add('message-error');
			}
		} catch (error) {
			console.error(error);
			formMessageDiv.textContent = 'A problem occurred. Please try again later.';
			formMessageDiv.classList.add('message-error');
		}
	});
</script>

<%- include('partials/footer') %>